# ─── Juspay credentials ───────────────────────────────────────────────────────
# NEVER commit your real .env file. Copy this file to .env and fill in the values.
JUSPAY_API_KEY=your_juspay_api_key_here
JUSPAY_BASE_URL=https://sandbox.juspay.in

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Public URL of this backend (used as return_url in Juspay session creation)
BACKEND_URL=http://localhost:3000

# For production, restrict CORS to your app domain
# ALLOWED_ORIGIN=https://yourdomain.com
